<!-- Hero Banner -->
<div class="lists-hero">
  <div class="lists-hero__content">
    <h1 class="lists-hero__title">Save any kind of movies</h1>
    <% if @lists.any? %>
      <p class="lists-hero__subtitle"><%= @lists.first.name %></p>
    <% end %>
  </div>
</div>

<!-- My Lists Section -->
<div class="lists-section">
  <div class="lists-section__header">
    <h2 class="lists-section__title">My Lists</h2>
    <%= link_to "Create a movie list", new_list_path, class: "btn-create-list" %>
  </div>

  <div class="lists-grid">
    <% @lists.each do |list| %>
      <%= link_to list_path(list), class: "list-card",
      style: "background-image: url(#{cl_image_path(list.photo.key)}" do %>
        <div class="list-card__overlay"></div>
        <span class="list-card__name"><%= list.name %></span>
      <% end %>
    <% end %>
  </div>
</div>
